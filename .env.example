APP_ENV=development
API_PREFIX=/api
API_KEY=replace_with_a_strong_random_value
DATABASE_URL=postgresql://nexus:replace_with_a_strong_password@db:5432/nexus
# Select the LLM backend: ollama, openai, or anthropic.
LLM_PROVIDER=ollama
# Model name for the selected backend.
LLM_MODEL=llama3.2:1b
# Required only when LLM_PROVIDER=openai.
OPENAI_API_KEY=
# Required only when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
# Ollama settings remain available when LLM_PROVIDER=ollama.
OLLAMA_BASE_URL=http://ollama:11434
MAX_ITERATIONS=3
MAX_RUN_SECONDS=900
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_NUM_PREDICT=480
OLLAMA_KEEP_ALIVE=20m
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5
TAVILY_API_KEY=replace_with_your_tavily_api_key
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_TIMEOUT_SECONDS=20
ENFORCE_REPORT_COMPLETENESS=true
RUN_REQUESTS_PER_MINUTE=10
REQUIRE_API_KEY=true
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_ENABLED=false
# For production deployments, set RATE_LIMIT_ENABLED=true
TOKEN_LEDGER_V2=true
AUTH_RBAC_V2=true
SSE_RESUME_V2=true
API_CONTRACT_V2=true
QUOTA_DAILY_TOKENS=200000
JWT_SECRET=replace_with_strong_jwt_secret
JWT_ALGORITHM=HS256
JWT_ISSUER=
JWT_AUDIENCE=
IDEMPOTENCY_TTL_MINUTES=120
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOW_UNSAFE_PYTHON_TOOL=false
STRICT_MIGRATIONS=true
MAX_REQUEST_BODY_BYTES=2097152
CONTENT_SECURITY_POLICY=default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' http://localhost:5173 http://127.0.0.1:5173; frame-ancestors 'none'; base-uri 'self'
UPLOAD_MAX_FILES=5
UPLOAD_CONTEXT_MAX_CHARS=20000
LOG_LEVEL=INFO
VITE_API_BASE_URL=http://localhost:8000/api

# Docker Compose postgres defaults
POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=replace_with_a_strong_password

# Port overrides - set these if running both stacks simultaneously
# NEXUS_BACKEND_PORT=8001
# NEXUS_FRONTEND_PORT=5174
